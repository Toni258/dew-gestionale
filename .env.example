# URL base aggiuntivo per le API nel frontend buildato.
# Può restare vuoto se il frontend e il backend stanno dietro lo stesso dominio e Nginx inoltra già /api al backend.
VITE_API_BASE_URL=

# Path pubblico da cui il frontend legge le immagini dei piatti.
VITE_FOOD_IMAGES_PUBLIC_PATH=/food-images

# Serve solo in sviluppo con Vite dev server.
# In locale di solito punta al backend Node, ad esempio http://localhost:3001.
# In produzione non viene usato dal browser finale.
VITE_API_PROXY_TARGET=http://localhost:3001


